rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: is authenticated
    function isAuthed() {
      return request.auth != null;
    }

    // Helper: admin/staff role via custom claim `staff: true`
    function isAdmin() {
      return isAuthed() && request.auth.token.staff == true;
    }

    // timeclock (raw events) - admin only
    match /timeclock/{docId} {
      allow read, write: if isAdmin();
    }

    // sessions: admin sees all; users see only their own (studentId == auth uid)
    match /sessions/{docId} {
      allow read: if isAdmin() || (isAuthed() && resource.data.studentId == request.auth.uid);
      allow write: if isAdmin();
    }

    // warnings: admin sees all; users see only their own
    match /warnings/{docId} {
      allow read: if isAdmin() || (isAuthed() && resource.data.studentId == request.auth.uid);
      allow write: if isAdmin();
    }

    // Rewards catalog - readable by all authenticated users
    match /rewards/{docId} {
      allow read: if isAuthed();
      allow write: if isAdmin();
    }

    match /purchases/{docId} {
      allow read: if isAuthed();
      allow create, update, delete: if isAdmin();
    }

    // Reward purchases: admin sees all; users see only their own
    match /reward_purchases/{docId} {
      allow read: if isAdmin() || (isAuthed() && resource.data.studentId == request.auth.uid);
      allow write: if isAdmin();
    }

    // Pay periods - admin only (contains configuration/rates)
    match /pay_periods/{docId} {
      allow read, write: if isAdmin();
    }

    // Payroll: admin sees all; users see only their own record
    match /payroll/{docId} {
      allow read: if isAdmin() || (isAuthed() && resource.data.studentId == request.auth.uid);
      allow write: if isAdmin();
    }

    match /bank/{docId} {
      allow read, write: if isAdmin();
    }

    // Students: admin sees all; users see only their own doc (doc id == auth uid)
    match /students/{studentId} {
      allow read: if isAdmin() || (isAuthed() && request.auth.uid == studentId);
      allow write: if isAdmin();
    }

    // Scenario app collections: allow authenticated read/write
    match /attempts/{docId} {
      allow read, write: if isAuthed();
    }

    match /scenarios/{docId} {
      allow read, write: if isAuthed();
    }

    match /progress/{docId} {
      allow read, write: if isAuthed();
    }

    match /schools/{docId} {
      allow read, write: if isAuthed();
    }

    match /license/{docId} {
      allow read, write: if isAuthed();
    }

    match /users/{docId} {
      allow read, write: if isAuthed();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
